<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp">

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Announcement Title"
            android:background="@drawable/shape"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:layout_marginBottom="10dp"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/etMessage"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Announcement Message"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:layout_marginBottom="10dp"
            android:minLines="3"/>

        <Spinner
            android:id="@+id/spUserType"
            android:layout_marginTop="20dp"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:popupBackground="@color/white"
            android:layout_marginBottom="10dp"/>

        <Spinner
            android:id="@+id/spDepartment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="@drawable/shape"
            android:popupBackground="@color/white"
            android:layout_marginBottom="10dp"/>

        <Spinner
            android:id="@+id/spClassYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="@drawable/shape"
            android:popupBackground="@color/white"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnSendAnnouncement"
            android:layout_gravity="center"
            android:backgroundTint="#4CDEED"
            android:textSize="20dp"
            android:layout_marginTop="20dp"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send Announcement"/>
    </LinearLayout>
</ScrollView>
