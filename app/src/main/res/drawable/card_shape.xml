<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <corners android:radius="16dp" />
    <solid android:color="@color/white" />
    <stroke android:width="2dp" android:color="#4CDEED" />
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />
    <shadowColor android:color="@color/black" />
    <shadowDx android:value="2" />
    <shadowDy android:value="2" />
    <shadowRadius android:value="4" />
</shape>

    <!-- This will give a nice card-like shape with rounded corners and a border! 🚀 -->
